<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#33FFB74D" />
            <stroke
                android:width="1dp"
                android:color="#66FFB74D" />
        </shape>
    </item>

    <!-- Focused state -->
    <item android:state_focused="true">
        <shape android:shape="oval">
            <solid android:color="#22FFB74D" />
            <stroke
                android:width="1dp"
                android:color="#44FFB74D" />
        </shape>
    </item>

    <!-- Normal state -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#22FFB74D" />
        </shape>
    </item>

</selector>
