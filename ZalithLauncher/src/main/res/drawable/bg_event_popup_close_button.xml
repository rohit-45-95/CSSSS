<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#111111" />
            <stroke
                android:width="1dp"
                android:color="#44FFB538" />
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="oval">
            <solid android:color="#0A0A0A" />
            <stroke
                android:width="1dp"
                android:color="#66FFB538" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <solid android:color="#070707" />
            <stroke
                android:width="1dp"
                android:color="#24B538" />
        </shape>
    </item>

</selector>