<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Amber gradient border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="135"
                android:startColor="#66FFB300"
                android:centerColor="#33FF8F00"
                android:endColor="#1AFFB300"
                android:type="linear" />
        </shape>
    </item>

    <!-- Inner dark fill -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="15dp" />
            <solid android:color="#111111" />
        </shape>
    </item>

</layer-list>
