<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/event_popup_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D9000000"
    android:clickable="true"
    android:focusable="true">

    <androidx.cardview.widget.CardView
        android:id="@+id/event_card"
        android:layout_width="@dimen/_300sdp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:contentPadding="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_event_popup"
            android:orientation="vertical"
            android:paddingBottom="18dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp">

                <ImageButton
                    android:id="@+id/btn_close"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="end"
                    android:background="@drawable/bg_event_popup_close_button"
                    android:padding="6dp"
                    android:src="@drawable/ic_close"
                    android:tint="#F2F4F8"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Close" />
            </FrameLayout>

            <ImageView
                android:id="@+id/promo_image"
                android:layout_width="match_parent"
                android:layout_height="208dp"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="-4dp"
                android:adjustViewBounds="true"
                android:contentDescription="Promotion"
                android:foreground="?attr/selectableItemBackground"
                android:scaleType="fitCenter"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/promo_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:letterSpacing="0.03"
                android:textColor="#F5F7FA"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/promo_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginHorizontal="18dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:textColor="#E0E5EB"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/promo_action_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_event_popup_action_button"
                android:gravity="center"
                android:letterSpacing="0.06"
                android:textColor="#24B538"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <androidx.appcompat.widget.AppCompatCheckBox
                android:id="@+id/checkbox_dont_show"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_gravity="center_horizontal"
                android:buttonTint="#24B538"
                android:text="Do not show again"
                android:textColor="#24B538"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
