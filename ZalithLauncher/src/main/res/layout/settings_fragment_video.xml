<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none"
    tools:ignore="UseSwitchCompatOrMaterialXml">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layoutAnimation="@anim/layout_anim_video_pro"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="16dp"
        android:paddingEnd="14dp"
        android:paddingBottom="28dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vid_header"
                android:minHeight="96dp"
                android:paddingStart="18dp"
                android:paddingTop="18dp"
                android:paddingEnd="14dp"
                android:paddingBottom="18dp">

                <View
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:alpha="0.25"
                    android:background="@drawable/bg_vid_glow_green"
                    app:layout_constraintBottom_toBottomOf="@id/vid_header_icon_card"
                    app:layout_constraintEnd_toEndOf="@id/vid_header_icon_card"
                    app:layout_constraintStart_toStartOf="@id/vid_header_icon_card"
                    app:layout_constraintTop_toTopOf="@id/vid_header_icon_card" />

                <FrameLayout
                    android:id="@+id/vid_header_icon_card"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_vid_icon_holder_green"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/settings_header_icon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_setting_video"
                        app:tint="#24B538" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/vid_header_badge"
                    app:layout_constraintStart_toEndOf="@id/vid_header_icon_card"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.03"
                        android:text="@string/setting_category_video"
                        android:textColor="#FFFFFF"
                        android:textSize="21sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif"
                        android:text="Renderer, display &amp; performance"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="48dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_vid_accent_line" />

                </LinearLayout>

                <TextView
                    android:id="@+id/vid_header_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_vid_badge_green"
                    android:fontFamily="sans-serif-bold"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="GPU"
                    android:textColor="#24B538"
                    android:textSize="9sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/settings_header_art"
                    android:layout_width="80dp"
                    android:layout_height="70dp"
                    android:alpha="0.12"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_settings_art"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:background="@drawable/bg_vid_accent_line" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:text="RENDERER &amp; DRIVER"
                android:textColor="#8024B538"
                android:textSize="11sp" />

        </LinearLayout>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/video_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_vid_panel"
            android:orientation="vertical"
            android:padding="10dp">

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/renderer_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vid_row"
                android:minHeight="78dp"
                android:padding="14dp"
                android:stateListAnimator="@animator/anim_vid_pro_press">

                <View
                    android:id="@+id/renderer_accent"
                    android:layout_width="4dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_vid_accent_line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/renderer_accent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/renderer_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/setting_renderer_title"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/renderer_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_vid_value_chip"
                            android:fontFamily="sans-serif"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="4dp"
                            android:text="@string/generic_default"
                            android:textColor="#24B538"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/renderer_download"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_vid_action_btn"
                        android:contentDescription="@string/setting_category_download"
                        android:padding="10dp"
                        android:src="@drawable/ic_download"
                        app:tint="#24B538" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/renderer_local_import_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_vid_row"
                android:minHeight="78dp"
                android:padding="14dp"
                android:stateListAnimator="@animator/anim_vid_pro_press">

                <View
                    android:id="@+id/import_accent"
                    android:layout_width="4dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_vid_accent_line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/import_accent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/renderer_local_import_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/setting_renderer_local_import_title"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/renderer_local_import_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/setting_renderer_local_import_desc"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/renderer_local_import_manage"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_vid_action_btn"
                        android:contentDescription="@string/setting_renderer_local_manage"
                        android:padding="10dp"
                        android:src="@drawable/ic_setting"
                        app:tint="#24B538" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/driver_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_vid_row"
                android:minHeight="78dp"
                android:padding="14dp"
                android:stateListAnimator="@animator/anim_vid_pro_press">

                <View
                    android:id="@+id/driver_accent"
                    android:layout_width="4dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_vid_accent_line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/driver_accent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/driver_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/setting_driver_title"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/driver_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_vid_value_chip"
                            android:fontFamily="sans-serif"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="4dp"
                            android:text="@string/generic_default"
                            android:textColor="#24B538"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/driver_download"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_vid_action_btn"
                        android:contentDescription="@string/setting_category_download"
                        android:padding="10dp"
                        android:src="@drawable/ic_download"
                        app:tint="#24B538" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:background="@drawable/bg_vid_accent_line" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:text="DISPLAY"
                android:textColor="#8024B538"
                android:textSize="11sp" />

        </LinearLayout>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_vid_panel"
            android:orientation="vertical"
            android:padding="10dp">

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/ignoreNotch_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vid_row"
                android:minHeight="78dp"
                android:padding="14dp"
                android:stateListAnimator="@animator/anim_vid_pro_press">

                <View
                    android:id="@+id/notch_accent"
                    android:layout_width="4dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_vid_accent_line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/notch_accent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/ignoreNotch_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/setting_ignore_notch_title"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/ignoreNotch_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/setting_ignore_notch_desc"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/ignoreNotch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:showText="false"
                        android:splitTrack="false"
                        android:thumbTint="@color/vid_switch_thumb"
                        android:trackTint="@color/vid_switch_track" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/ignoreNotchLauncher_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_vid_row"
                android:minHeight="78dp"
                android:padding="14dp"
                android:stateListAnimator="@animator/anim_vid_pro_press">

                <View
                    android:id="@+id/notch_launcher_accent"
                    android:layout_width="4dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_vid_accent_line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/notch_launcher_accent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/ignoreNotchLauncher_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/setting_launcher_ignore_notch_title"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/ignoreNotchLauncher_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/setting_launcher_ignore_notch_desc"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/ignoreNotchLauncher"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:showText="false"
                        android:splitTrack="false"
                        android:thumbTint="@color/vid_switch_thumb"
                        android:trackTint="@color/vid_switch_track" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/resolutionRatio_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_vid_row"
                android:padding="14dp"
                android:stateListAnimator="@animator/anim_vid_pro_press">

                <View
                    android:id="@+id/res_accent"
                    android:layout_width="4dp"
                    android:layout_height="56dp"
                    android:layout_alignParentStart="true"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_vid_accent_line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/res_accent"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/resolutionRatio_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/setting_resolution_scaler_title"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/resolutionRatio_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/setting_resolution_scaler_desc"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/resolutionRatio_preview"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_vid_value_chip"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="6dp"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/resolutionRatio_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_vid_green_chip"
                            android:fontFamily="sans-serif-bold"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="6dp"
                            android:textColor="#24B538"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/resolutionRatio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:max="300"
                        android:min="25"
                        android:progressTint="#24B538"
                        android:thumbTint="#24B538" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:background="@drawable/bg_vid_accent_line" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:text="PERFORMANCE"
                android:textColor="#8024B538"
                android:textSize="11sp" />

        </LinearLayout>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_vid_panel"
            android:orientation="vertical"
            android:padding="10dp">

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/sustainedPerformance_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vid_row"
                android:minHeight="78dp"
                android:padding="14dp"
                android:stateListAnimator="@animator/anim_vid_pro_press">

                <View
                    android:id="@+id/sustained_accent"
                    android:layout_width="4dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_vid_accent_line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/sustained_accent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/sustainedPerformance_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/setting_sustained_performance_title"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/sustainedPerformance_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/setting_limit_overheating_throttling"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/sustainedPerformance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:showText="false"
                        android:splitTrack="false"
                        android:thumbTint="@color/vid_switch_thumb"
                        android:trackTint="@color/vid_switch_track" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/alternate_surface_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
