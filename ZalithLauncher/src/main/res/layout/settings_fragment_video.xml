<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_video_settings_screen"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:ignore="UseSwitchCompatOrMaterialXml">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layoutAnimation="@anim/layout_anim_video_settings"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="14dp"
        android:paddingEnd="12dp"
        android:paddingBottom="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_video_settings_header"
                android:minHeight="110dp"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingEnd="14dp"
                android:paddingBottom="16dp">

                <FrameLayout
                    android:id="@+id/video_header_icon_holder"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_video_setting_action"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_setting_video"
                        app:tint="#FFFFB74D" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/video_header_badge"
                    app:layout_constraintStart_toEndOf="@id/video_header_icon_holder"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_category_video"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Renderer, display and performance controls"
                        android:textColor="#B3FFFFFF"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="42dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="9dp"
                        android:background="@drawable/bg_video_setting_accent" />

                </LinearLayout>

                <TextView
                    android:id="@+id/video_header_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_video_setting_chip_accent"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="GRAPHICS"
                    android:textColor="#FFFFCC80"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/video_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_video_settings_panel"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="10dp"
                android:text="RENDERER &amp; DRIVER"
                android:textColor="#FFFFB74D"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/renderer_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_video_setting_row"
                android:minHeight="84dp"
                android:padding="12dp"
                android:stateListAnimator="@animator/anim_video_setting_press">

                <View
                    android:layout_width="4dp"
                    android:layout_height="42dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_video_setting_accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:id="@+id/renderer_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_renderer_title"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/renderer_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/generic_default"
                            android:textColor="#B3FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/renderer_download"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_video_setting_action"
                        android:contentDescription="@string/setting_category_download"
                        android:padding="9dp"
                        android:src="@drawable/ic_download"
                        app:tint="#FFFFB74D" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/renderer_local_import_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_video_setting_row"
                android:minHeight="84dp"
                android:padding="12dp"
                android:stateListAnimator="@animator/anim_video_setting_press">

                <View
                    android:layout_width="4dp"
                    android:layout_height="42dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_video_setting_accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:id="@+id/renderer_local_import_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_renderer_local_import_title"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/renderer_local_import_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/setting_renderer_local_import_desc"
                            android:textColor="#B3FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/renderer_local_import_manage"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_video_setting_action"
                        android:contentDescription="@string/setting_renderer_local_manage"
                        android:padding="9dp"
                        android:src="@drawable/ic_setting"
                        app:tint="#FFFFB74D" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/driver_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_video_setting_row"
                android:minHeight="84dp"
                android:padding="12dp"
                android:stateListAnimator="@animator/anim_video_setting_press">

                <View
                    android:layout_width="4dp"
                    android:layout_height="42dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_video_setting_accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:id="@+id/driver_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_driver_title"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/driver_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/generic_default"
                            android:textColor="#B3FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/driver_download"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_video_setting_action"
                        android:contentDescription="@string/setting_category_download"
                        android:padding="9dp"
                        android:src="@drawable/ic_download"
                        app:tint="#FFFFB74D" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:text="DISPLAY"
                android:textColor="#FFFFB74D"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/ignoreNotch_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_video_setting_row"
                android:minHeight="84dp"
                android:padding="12dp"
                android:stateListAnimator="@animator/anim_video_setting_press">

                <View
                    android:layout_width="4dp"
                    android:layout_height="42dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_video_setting_accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:id="@+id/ignoreNotch_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_ignore_notch_title"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/ignoreNotch_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/setting_ignore_notch_desc"
                            android:textColor="#B3FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/ignoreNotch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:showText="false"
                        android:splitTrack="false"
                        android:thumbTint="@color/video_setting_switch_thumb"
                        android:trackTint="@color/video_setting_switch_track" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/ignoreNotchLauncher_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_video_setting_row"
                android:minHeight="84dp"
                android:padding="12dp"
                android:stateListAnimator="@animator/anim_video_setting_press">

                <View
                    android:layout_width="4dp"
                    android:layout_height="42dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_video_setting_accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:id="@+id/ignoreNotchLauncher_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_launcher_ignore_notch_title"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/ignoreNotchLauncher_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/setting_launcher_ignore_notch_desc"
                            android:textColor="#B3FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/ignoreNotchLauncher"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:showText="false"
                        android:splitTrack="false"
                        android:thumbTint="@color/video_setting_switch_thumb"
                        android:trackTint="@color/video_setting_switch_track" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/resolutionRatio_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_video_setting_row"
                android:padding="12dp"
                android:stateListAnimator="@animator/anim_video_setting_press">

                <View
                    android:layout_width="4dp"
                    android:layout_height="54dp"
                    android:layout_alignParentStart="true"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_video_setting_accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/resolutionRatio_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_resolution_scaler_title"
                        android:textColor="#FFFFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/resolutionRatio_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="@string/setting_resolution_scaler_desc"
                        android:textColor="#B3FFFFFF"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/resolutionRatio_preview"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_video_setting_chip"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:paddingStart="10dp"
                            android:paddingTop="7dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="7dp"
                            android:textColor="#FFFFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/resolutionRatio_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_video_setting_chip_accent"
                            android:paddingStart="10dp"
                            android:paddingTop="7dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="7dp"
                            android:textColor="#FFFFCC80"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/resolutionRatio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:max="300"
                        android:min="25"
                        android:progressTint="#FFFFB74D"
                        android:thumbTint="#FFFFB74D" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:text="PERFORMANCE"
                android:textColor="#FFFFB74D"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/sustainedPerformance_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_video_setting_row"
                android:minHeight="84dp"
                android:padding="12dp"
                android:stateListAnimator="@animator/anim_video_setting_press">

                <View
                    android:layout_width="4dp"
                    android:layout_height="42dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_video_setting_accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:id="@+id/sustainedPerformance_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_sustained_performance_title"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/sustainedPerformance_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/setting_limit_overheating_throttling"
                            android:textColor="#B3FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/sustainedPerformance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:showText="false"
                        android:splitTrack="false"
                        android:thumbTint="@color/video_setting_switch_thumb"
                        android:trackTint="@color/video_setting_switch_track" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/alternate_surface_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_video_setting_row"
                android:minHeight="84dp"
                android:padding="12dp"
                android:stateListAnimator="@animator/anim_video_setting_press">

                <View
                    android:layout_width="4dp"
                    android:layout_height="42dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_video_setting_accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:id="@+id/alternate_surface_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_use_surface_view_title"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/alternate_surface_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/setting_use_surface_view_desc"
                            android:textColor="#B3FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/alternate_surface"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:showText="false"
                        android:splitTrack="false"
                        android:thumbTint="@color/video_setting_switch_thumb"
                        android:trackTint="@color/video_setting_switch_track" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                android:id="@+id/force_vsync_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_video_setting_row"
                android:minHeight="84dp"
                android:padding="12dp"
                android:stateListAnimator="@animator/anim_video_setting_press">

                <View
                    android:layout_width="4dp"
                    android:layout_height="42dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_video_setting_accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:id="@+id/force_vsync_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_force_vsync_title"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/force_vsync_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/setting_limit_overheating_throttling"
                            android:textColor="#B3FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/force_vsync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:showText="false"
                        android:splitTrack="false"
                        android:thumbTint="@color/video_setting_switch_thumb"
                        android:trackTint="@color/video_setting_switch_track" />

                </LinearLayout>
            </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
