<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_about_member_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp"
    android:stateListAnimator="@animator/anim_about_btn_press">

    <View
        android:layout_width="4dp"
        android:layout_height="36dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_about_section_strip" />

    <FrameLayout
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_about_avatar_holder">

        <ImageView
            android:id="@+id/member_avatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile_default" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/member_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-bold"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/member_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_about_version_chip"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:textColor="#24B538"
            android:textSize="10sp" />

    </LinearLayout>

    <ImageView
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:src="@drawable/ic_chevron_right"
        app:tint="#2224B538" />

</LinearLayout>
