<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/customctrl_drawerlayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ═══════════════════════════════════════ -->
    <!-- MAIN CONTENT                            -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Background -->
    <ImageView
        android:id="@+id/background_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- Main overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Ambient top glow -->
        <View
            android:layout_width="280dp"
            android:layout_height="180dp"
            android:alpha="0.08"
            android:background="@drawable/bg_ctrl_editor_glow"
            android:translationX="-40dp"
            android:translationY="-50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Ambient bottom-right glow -->
        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:alpha="0.05"
            android:background="@drawable/bg_ctrl_editor_glow"
            android:translationX="60dp"
            android:translationY="50dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Hint pill — top-right corner -->
        <LinearLayout
            android:id="@+id/hint_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_ctrl_hint_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_info"
                app:tint="#24B538" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/controls_tip"
                android:textColor="#B3FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Top-left control editor badge -->
        <LinearLayout
            android:id="@+id/editor_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_ctrl_editor_badge"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_ctrl_status_dot" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.06"
                android:text="CONTROL EDITOR"
                android:textColor="#24B538"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Bottom edge glow bar -->
        <View
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="0dp"
            android:background="@drawable/bg_ctrl_bottom_glow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Control layout — full screen -->
        <com.craftstudio.launcher.customcontrols.ControlLayout
            android:id="@+id/customctrl_controllayout"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════ -->
    <!-- DRAWER: Right panel                     -->
    <!-- ═══════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/customctrl_navigation_view"
        android:layout_width="270dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_ctrl_drawer_panel"
        android:clipToPadding="false"
        android:elevation="12dp"
        android:fitsSystemWindows="false"
        android:translationZ="6dp" />

</androidx.drawerlayout.widget.DrawerLayout>
