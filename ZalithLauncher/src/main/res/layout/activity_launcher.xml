<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0E1A"
    tools:ignore="ContentDescription">

    <!-- Background -->
    <ImageView
        android:id="@+id/background_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Gradient overlay on background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_overlay"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_48sdp"
        android:background="#CC0D0E1A"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- App Logo/Icon (optional, left of title) -->
        <ImageView
            android:id="@+id/app_logo"
            android:layout_width="@dimen/_28sdp"
            android:layout_height="@dimen/_28sdp"
            android:layout_marginStart="@dimen/_12sdp"
            android:src="@drawable/ic_cs_launcher_logo"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- App Title -->
        <com.craftstudio.launcher.ui.view.AnimTextView
            android:id="@+id/app_title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:layout_marginEnd="@dimen/_8sdp"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="#FFB74D"
            android:textSize="@dimen/_16ssp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/app_logo"
            app:layout_constraintEnd_toStartOf="@id/download_button"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Download Button -->
        <ImageButton
            android:id="@+id/download_button"
            android:layout_width="@dimen/_40sdp"
            android:layout_height="0dp"
            android:layout_marginEnd="@dimen/_4sdp"
            android:layout_marginVertical="@dimen/_6sdp"
            android:background="@drawable/btn_icon_bg"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_download"
            android:padding="@dimen/_8sdp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/setting_button"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFB74D" />

        <!-- Settings Button -->
        <ImageButton
            android:id="@+id/setting_button"
            android:layout_width="@dimen/_40sdp"
            android:layout_height="0dp"
            android:layout_marginEnd="@dimen/_8sdp"
            android:layout_marginVertical="@dimen/_6sdp"
            android:background="@drawable/btn_icon_bg"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_menu_settings"
            android:padding="@dimen/_8sdp"
            android:visibility="visible"
            app:tint="#E8EBEF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Divider below top bar -->
    <View
        android:id="@+id/shadowView"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFB74D"
        app:layout_constraintTop_toBottomOf="@id/top_layout" />

    <!-- Main Content Fragment -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/container_fragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/progress_shadowView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shadowView" />

    <!-- Divider above progress -->
    <View
        android:id="@+id/progress_shadowView"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#33FFB74D"
        app:layout_constraintBottom_toTopOf="@+id/progress_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Progress Bar -->
    <com.kdt.mcgui.ProgressLayout
        android:id="@+id/progress_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Notice Popup -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/notice_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/_12sdp"
        android:background="@drawable/notice_card_bg"
        android:padding="@dimen/_16sdp"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/notice_guideline"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_layout"
        app:layout_constraintVertical_bias="0.333">

        <TextView
            android:id="@+id/notice_title_view"
            style="@style/TextAppearance.AppCompat.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:text="@string/announcements_title"
            android:textColor="#24B538"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Divider under title -->
        <View
            android:id="@+id/notice_divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/_8sdp"
            android:background="#3324B538"
            app:layout_constraintTop_toBottomOf="@id/notice_title_view"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginVertical="@dimen/_8sdp"
            android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
            app:layout_constraintBottom_toTopOf="@+id/notice_got_button"
            app:layout_constraintTop_toBottomOf="@+id/notice_divider">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/notice_message_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#CFD8DC"
                    android:textIsSelectable="true"
                    android:lineSpacingMultiplier="1.4"
                    android:textSize="@dimen/_13sdp" />

                <TextView
                    android:id="@+id/notice_date_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#78909C"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:textSize="@dimen/_11sdp"
                    android:gravity="end" />

            </LinearLayout>

        </ScrollView>

        <com.craftstudio.launcher.ui.view.AnimButton
            android:id="@+id/notice_got_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:backgroundTint="#24B538"
            android:textStyle="bold"
            android:text="@string/generic_close"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/notice_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.35" />

    <!-- Hair / Easter egg -->
    <ImageView
        android:id="@+id/hair"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_hair" />

    <FrameLayout
        android:id="@+id/fl_download_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6091526"
        android:visibility="gone"
        android:elevation="24dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/iv_cs_logo_anim"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/ic_cs_launcher_logo" />

            <ProgressBar
                android:id="@+id/pb_ring"
                style="@android:style/Widget.ProgressBar.Large"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:layout_marginTop="-104dp"
                android:indeterminate="true"
                android:indeterminateTint="#FF8F00" />

            <TextView
                android:id="@+id/tv_download_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Preparing CS Launcher..."
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_download_pct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="0%"
                android:textColor="#FF8F00"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/pb_linear"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="240dp"
                android:layout_height="4dp"
                android:layout_marginTop="10dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#FF8F00"
                android:progressBackgroundTint="#33FF8F00" />

            <TextView
                android:id="@+id/tv_download_step"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="#B3FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
