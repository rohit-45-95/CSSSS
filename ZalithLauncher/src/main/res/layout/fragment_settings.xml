<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    tools:context="com.craftstudio.launcher.ui.fragment.SettingsFragment">

    <!-- ===== MAIN SCROLL CONTAINER ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ===== HEADER CARD: Settings title + Minecraft art ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <!-- Amber border via gradient background behind card -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_settings_header_border">

                    <!-- Gear icon box -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginStart="16dp"
                        app:cardBackgroundColor="#1A1500"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/settings_header_icon"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_setting_launcher"
                            app:tint="#FFB300" />

                    </androidx.cardview.widget.CardView>

                    <!-- Title + subtitle -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/settings_header_art"
                        app:layout_constraintStart_toEndOf="@+id/settings_header_icon_card"
                        app:layout_constraintTop_toTopOf="parent">

                        <!-- "Settings" big title -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Settings"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <!-- Subtitle -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Customize your launcher experience"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Minecraft lantern art on right -->
                    <ImageView
                        android:id="@+id/settings_header_art"
                        android:layout_width="120dp"
                        android:layout_height="100dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_settings_art"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== TOP ROW: Video | Controls | Game ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- VIDEO CARD -->
                <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                    android:id="@+id/video_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#111111"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_settings_card_border"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingTop="20dp"
                            android:paddingBottom="16dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <!-- Hexagon icon container -->
                            <FrameLayout
                                android:layout_width="72dp"
                                android:layout_height="72dp">

                                <ImageView
                                    android:layout_width="72dp"
                                    android:layout_height="72dp"
                                    android:src="@drawable/bg_hex_amber"
                                    android:scaleType="fitCenter" />

                                <ImageView
                                    android:id="@+id/video_image"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_setting_video"
                                    app:tint="#FFB300" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Video"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center"
                                android:text="Configure graphics, display, and performance settings."
                                android:textColor="#888888"
                                android:textSize="10sp" />

                            <!-- Arrow button -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="36dp"
                                android:layout_height="22dp"
                                android:layout_marginTop="12dp"
                                app:cardBackgroundColor="#1A1500"
                                app:cardCornerRadius="11dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#FFB300" />

                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

                <!-- CONTROLS CARD -->
                <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                    android:id="@+id/controls_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#111111"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_settings_card_border"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingTop="20dp"
                            android:paddingBottom="16dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <FrameLayout
                                android:layout_width="72dp"
                                android:layout_height="72dp">

                                <ImageView
                                    android:layout_width="72dp"
                                    android:layout_height="72dp"
                                    android:src="@drawable/bg_hex_amber"
                                    android:scaleType="fitCenter" />

                                <ImageView
                                    android:id="@+id/controls_image"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_menu_custom_controls"
                                    app:tint="#FFB300" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Controls"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center"
                                android:text="Customize touch, key mappings, and control preferences."
                                android:textColor="#888888"
                                android:textSize="10sp" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="36dp"
                                android:layout_height="22dp"
                                android:layout_marginTop="12dp"
                                app:cardBackgroundColor="#1A1500"
                                app:cardCornerRadius="11dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#FFB300" />

                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

                <!-- GAME CARD -->
                <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                    android:id="@+id/game_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#111111"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_settings_card_border"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingTop="20dp"
                            android:paddingBottom="16dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <FrameLayout
                                android:layout_width="72dp"
                                android:layout_height="72dp">

                                <ImageView
                                    android:layout_width="72dp"
                                    android:layout_height="72dp"
                                    android:src="@drawable/bg_hex_amber"
                                    android:scaleType="fitCenter" />

                                <ImageView
                                    android:id="@+id/game_image"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_setting_game"
                                    app:tint="#FFB300" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/setting_category_game"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center"
                                android:text="Adjust gameplay, world, and in-game options."
                                android:textColor="#888888"
                                android:textSize="10sp" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="36dp"
                                android:layout_height="22dp"
                                android:layout_marginTop="12dp"
                                app:cardBackgroundColor="#1A1500"
                                app:cardCornerRadius="11dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#FFB300" />

                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            </LinearLayout>

            <!-- ===== BOTTOM ROW: Launcher | Experimental ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- LAUNCHER CARD (horizontal layout - icon left, text right) -->
                <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                    android:id="@+id/launcher_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#111111"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_settings_card_border"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingTop="20dp"
                            android:paddingBottom="16dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <FrameLayout
                                android:layout_width="72dp"
                                android:layout_height="72dp">

                                <ImageView
                                    android:layout_width="72dp"
                                    android:layout_height="72dp"
                                    android:src="@drawable/bg_hex_amber"
                                    android:scaleType="fitCenter" />

                                <ImageView
                                    android:id="@+id/launcher_image"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_setting_launcher"
                                    app:tint="#FFB300" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/setting_category_launcher"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center"
                                android:text="Personalize launcher behavior, updates and integrations."
                                android:textColor="#888888"
                                android:textSize="10sp" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="36dp"
                                android:layout_height="22dp"
                                android:layout_marginTop="12dp"
                                app:cardBackgroundColor="#1A1500"
                                app:cardCornerRadius="11dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#FFB300" />

                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

                <!-- EXPERIMENTAL CARD -->
                <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                    android:id="@+id/experimental_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#111111"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_settings_card_border"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingTop="20dp"
                            android:paddingBottom="16dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <FrameLayout
                                android:layout_width="72dp"
                                android:layout_height="72dp">

                                <ImageView
                                    android:layout_width="72dp"
                                    android:layout_height="72dp"
                                    android:src="@drawable/bg_hex_amber"
                                    android:scaleType="fitCenter" />

                                <ImageView
                                    android:id="@+id/experimental_image"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_setting_experimental"
                                    app:tint="#FFB300" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/setting_category_experimental"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center"
                                android:text="Enable experimental features and advanced options."
                                android:textColor="#888888"
                                android:textSize="10sp" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="36dp"
                                android:layout_height="22dp"
                                android:layout_marginTop="12dp"
                                app:cardBackgroundColor="#1A1500"
                                app:cardCornerRadius="11dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#FFB300" />

                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== HIDDEN: settings_viewpager - kept for code compatibility ===== -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/settings_viewpager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/settings_layout"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ===== HIDDEN: settings_layout sidebar - kept for code compatibility ===== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/settings_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/shadowView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.angcyo.tablayout.DslTabLayout
            android:id="@+id/settings_tab"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintEnd_toStartOf="@+id/shadowView"
            app:layout_constraintStart_toStartOf="parent">
        </com.angcyo.tablayout.DslTabLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
