<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F1A">

    <LinearLayout
        android:id="@+id/topView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#1A1A2E"
        android:gravity="center">
        
        <TextView
            android:id="@+id/errorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Craft Studio Crashed"
            android:textColor="#FF3366"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/centerText"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:visibility="gone"
        android:textColor="#FFFFFF"
        android:textSize="24sp" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/errorTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tip: Check your JVM arguments or RAM allocation."
                android:textColor="#00E5FF"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/errorNoScreenshot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Screenshots disabled for security reasons."
                android:textColor="#FFaa00"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/errorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textIsSelectable="true"
                android:fontFamily="monospace"
                android:text="Crash details will appear here..." />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/errorRestart"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Restart"
            android:backgroundTint="#7B2CBF"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/shareLog"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Share Log"
            android:layout_marginHorizontal="8dp"
            android:backgroundTint="#00E5FF"
            android:textColor="#000000" />

        <Button
            android:id="@+id/errorConfirm"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Exit"
            android:backgroundTint="#FF3366"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>