<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_menu_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clipToPadding="false">

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:alpha="0.10"
        android:background="@drawable/bg_acc_glow"
        android:translationX="-50dp"
        android:translationY="-30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:alpha="0.06"
        android:background="@drawable/bg_acc_glow"
        android:translationX="70dp"
        android:translationY="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/account_operation_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.48" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/account_menu"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_acc_main_panel"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/account_operation_guideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/account_menu_top_glow"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_acc_top_glow"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/account_type_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_acc_header"
            android:padding="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/account_menu_top_glow">

            <FrameLayout
                android:id="@+id/acc_icon_frame"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_acc_icon_circle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/accounts_header_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_friends"
                    app:tint="#24B538"
                    tools:ignore="ContentDescription" />

            </FrameLayout>

            <TextView
                android:id="@+id/account_panel_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.06"
                android:text="ACCOUNTS"
                android:textColor="#24B538"
                android:textSize="15sp"
                app:layout_constraintEnd_toStartOf="@id/add_server"
                app:layout_constraintStart_toEndOf="@id/acc_icon_frame"
                app:layout_constraintTop_toTopOf="@id/acc_icon_frame" />

            <TextView
                android:id="@+id/account_panel_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="8dp"
                android:text="Microsoft &amp; Local accounts"
                android:textColor="#80FFFFFF"
                android:textSize="10sp"
                app:layout_constraintEnd_toStartOf="@id/add_server"
                app:layout_constraintStart_toEndOf="@id/acc_icon_frame"
                app:layout_constraintTop_toBottomOf="@id/account_panel_title" />

            <ImageView
                android:id="@+id/add_server"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_acc_action_btn"
                android:padding="9dp"
                android:src="@drawable/ic_more"
                android:stateListAnimator="@animator/anim_acc_press"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#24B538"
                tools:ignore="ContentDescription" />

            <com.angcyo.tablayout.DslTabLayout
                android:id="@+id/account_type_tab"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/account_panel_subtitle"
                app:tab_deselect_color="#80FFFFFF"
                app:tab_select_color="#24B538">

                <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                    android:id="@+id/add_microsoft_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_acc_tab_item"
                    android:minHeight="38dp"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="8dp"
                    android:stateListAnimator="@animator/anim_acc_tab_press">

                    <ImageView
                        android:id="@+id/add_microsoft_image"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_add"
                        app:tint="#24B538"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="6dp"
                        android:layout_toEndOf="@id/add_microsoft_image"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/account_microsoft_account"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp" />

                </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

                <com.craftstudio.launcher.ui.layout.AnimRelativeLayout
                    android:id="@+id/add_local_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_acc_tab_item"
                    android:minHeight="38dp"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="8dp"
                    android:stateListAnimator="@animator/anim_acc_tab_press">

                    <ImageView
                        android:id="@+id/add_local_image"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_add"
                        app:tint="#24B538"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="6dp"
                        android:layout_toEndOf="@id/add_local_image"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/account_local_account"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp" />

                </com.craftstudio.launcher.ui.layout.AnimRelativeLayout>

            </com.angcyo.tablayout.DslTabLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/accounts_recycler"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_acc_list_surface"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:padding="8dp"
            android:scrollbars="none"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/account_type_layout" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/operation_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="6dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/account_operation_guideline"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/shadowView"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="28dp"
            android:background="@drawable/bg_acc_edge_glow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/operation_main_layout"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_acc_side_panel"
            android:padding="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/shadowView"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/operation_header_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <View
                    android:id="@+id/operation_header_marker"
                    android:layout_width="4dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_acc_accent_line" />

                <LinearLayout
                    android:id="@+id/operation_header_text_holder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/operation_header_small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="0.1"
                        android:text="SELECTED ACCOUNT"
                        android:textColor="#8024B538"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/operation_header_big"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif-bold"
                        android:text="Account Preview"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/operation_header_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Manage the currently selected account"
                android:textColor="#55FFFFFF"
                android:textSize="10sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/operation_header_row" />

            <View
                android:id="@+id/operation_divider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_acc_top_glow"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/operation_header_desc" />

            <androidx.core.widget.NestedScrollView
                android:id="@+id/operation_scroll"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:scrollbars="none"
                app:layout_constraintBottom_toTopOf="@id/return_button"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/operation_divider">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="4dp">

                    <FrameLayout
                        android:id="@+id/account_preview_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_acc_preview_card"
                        android:padding="1dp">

                        <include
                            android:id="@+id/view_account"
                            layout="@layout/view_account" />

                    </FrameLayout>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

            <com.craftstudio.launcher.ui.view.AnimButton
                android:id="@+id/return_button"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_acc_return_btn"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.06"
                android:stateListAnimator="@animator/anim_acc_press"
                android:text="@string/generic_return"
                android:textAllCaps="true"
                android:textColor="#000000"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>