<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Ambient glows -->
    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:alpha="0.10"
        android:background="@drawable/bg_about_glow"
        android:translationX="-60dp"
        android:translationY="-60dp" />

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.06"
        android:background="@drawable/bg_about_glow"
        android:layout_gravity="bottom|end"
        android:translationX="60dp"
        android:translationY="60dp" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/about_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- ════════════════════════════════ -->
            <!-- HEADER                           -->
            <!-- ════════════════════════════════ -->
            <FrameLayout
                android:id="@+id/header_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:paddingTop="36dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <!-- Logo holder -->
                    <FrameLayout
                        android:layout_width="130dp"
                        android:layout_height="130dp"
                        android:layout_gravity="center_horizontal">

                        <View
                            android:layout_width="130dp"
                            android:layout_height="130dp"
                            android:alpha="0.30"
                            android:background="@drawable/bg_about_logo_glow" />

                        <FrameLayout
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_about_logo_circle">

                            <ImageView
                                android:id="@+id/about_logo"
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:layout_gravity="center"
                                android:contentDescription="CS Launcher Logo"
                                android:src="@drawable/ic_logo" />

                        </FrameLayout>

                    </FrameLayout>

                    <!-- Title -->
                    <TextView
                        android:id="@+id/about_brand_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.15"
                        android:text="CS LAUNCHER V2"
                        android:textColor="#24B538"
                        android:textSize="22sp" />

                    <!-- Version -->
                    <TextView
                        android:id="@+id/about_version_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_about_version_chip"
                        android:paddingStart="14dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="5dp"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp" />

                    <!-- Accent line -->
                    <View
                        android:layout_width="60dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_about_accent_line" />

                </LinearLayout>
            </FrameLayout>

            <!-- ════════════════════════════════ -->
            <!-- CREDITS: PojavLauncher           -->
            <!-- ════════════════════════════════ -->
            <FrameLayout
                android:id="@+id/credits_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:paddingStart="18dp"
                android:paddingTop="8dp"
                android:paddingEnd="18dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_about_credits_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="20dp">

                    <!-- Top glow -->
                    <View
                        android:layout_width="80dp"
                        android:layout_height="3dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_about_accent_line" />

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_about_icon_circle">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:contentDescription="PojavLauncher"
                            android:src="@drawable/ic_pojav_full" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-bold"
                        android:text="Based on PojavLauncher"
                        android:textColor="#24B538"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.4"
                        android:text="Open source under GPL v3. Special thanks to the PojavLauncherTeam for their foundational work."
                        android:textColor="#66FFFFFF"
                        android:textSize="11sp" />

                    <com.craftstudio.launcher.ui.view.AnimButton
                        android:id="@+id/credits_github_button"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_about_outline_btn"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="View on GitHub"
                        android:textAllCaps="false"
                        android:textColor="#24B538"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </FrameLayout>

            <!-- ════════════════════════════════ -->
            <!-- TEAM: DEVELOPERS                 -->
            <!-- ════════════════════════════════ -->
            <FrameLayout
                android:id="@+id/team_dev_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Section header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_about_section_header"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="10dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@drawable/bg_about_section_strip" />

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_about_section_icon">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:contentDescription="Developer"
                                android:src="@drawable/ic_role_dev"
                                app:tint="#24B538" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-bold"
                            android:letterSpacing="0.1"
                            android:text="DEVELOPERS"
                            android:textColor="#24B538"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_about_version_chip"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="4dp"
                            android:text="TEAM"
                            android:textColor="#5524B538"
                            android:textSize="9sp" />

                    </LinearLayout>

                    <!-- Dev cards -->
                    <LinearLayout
                        android:id="@+id/dev_cards_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />

                </LinearLayout>
            </FrameLayout>

            <!-- ════════════════════════════════ -->
            <!-- TEAM: FOUNDERS                   -->
            <!-- ════════════════════════════════ -->
            <FrameLayout
                android:id="@+id/team_founder_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_about_section_header"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="10dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@drawable/bg_about_section_strip" />

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_about_section_icon">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:contentDescription="Founder"
                                android:src="@drawable/ic_role_founder"
                                app:tint="#24B538" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-bold"
                            android:letterSpacing="0.1"
                            android:text="FOUNDERS"
                            android:textColor="#24B538"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_about_version_chip"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="4dp"
                            android:text="TEAM"
                            android:textColor="#5524B538"
                            android:textSize="9sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/founder_cards_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />

                </LinearLayout>
            </FrameLayout>

            <!-- ════════════════════════════════ -->
            <!-- TEAM: PROVIDERS & STAFF          -->
            <!-- ════════════════════════════════ -->
            <FrameLayout
                android:id="@+id/team_staff_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_about_section_header"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="10dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@drawable/bg_about_section_strip" />

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_about_section_icon">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:contentDescription="Staff"
                                android:src="@drawable/ic_role_staff"
                                app:tint="#24B538" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-bold"
                            android:letterSpacing="0.1"
                            android:text="PROVIDERS &amp; STAFF"
                            android:textColor="#24B538"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_about_version_chip"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="4dp"
                            android:text="TEAM"
                            android:textColor="#5524B538"
                            android:textSize="9sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/staff_cards_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />

                </LinearLayout>
            </FrameLayout>

            <!-- ════════════════════════════════ -->
            <!-- FOOTER: Community Links          -->
            <!-- ════════════════════════════════ -->
            <FrameLayout
                android:id="@+id/footer_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:paddingStart="18dp"
                android:paddingTop="28dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_about_footer_card"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="22dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="22dp">

                    <!-- Top accent -->
                    <View
                        android:layout_width="50dp"
                        android:layout_height="3dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="14dp"
                        android:background="@drawable/bg_about_accent_line" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="0.1"
                        android:text="JOIN THE COMMUNITY"
                        android:textColor="#24B538"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="4dp"
                        android:text="Connect with us and other players"
                        android:textColor="#55FFFFFF"
                        android:textSize="11sp" />

                    <!-- Discord -->
                    <com.craftstudio.launcher.ui.view.AnimButton
                        android:id="@+id/footer_discord_button"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_about_green_btn"
                        android:fontFamily="sans-serif-bold"
                        android:stateListAnimator="@animator/anim_about_btn_press"
                        android:text="JOIN DISCORD"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textSize="14sp" />

                    <!-- Website -->
                    <com.craftstudio.launcher.ui.view.AnimButton
                        android:id="@+id/footer_website_button"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_about_outline_btn"
                        android:fontFamily="sans-serif-bold"
                        android:stateListAnimator="@animator/anim_about_btn_press"
                        android:text="VISIT WEBSITE"
                        android:textAllCaps="false"
                        android:textColor="#24B538"
                        android:textSize="14sp" />

                    <!-- Return -->
                    <com.craftstudio.launcher.ui.view.AnimButton
                        android:id="@+id/return_button"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_about_ghost_btn"
                        android:fontFamily="sans-serif"
                        android:stateListAnimator="@animator/anim_about_btn_press"
                        android:text="@string/generic_return"
                        android:textAllCaps="false"
                        android:textColor="#55FFFFFF"
                        android:textSize="12sp" />

                    <!-- Footer note -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="18dp"
                        android:text="Made with ❤ by CraftStudio Team"
                        android:textColor="#2224B538"
                        android:textSize="10sp" />

                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
